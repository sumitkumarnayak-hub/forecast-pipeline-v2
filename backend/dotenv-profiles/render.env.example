# RENDER production profile — copy to render.env, paste secrets, import to Render dashboard
#   copy backend\env\profiles\render.env.example backend\env\profiles\render.env
# Import render.env on Render → Environment → Import (not used locally as active .env)
# Switch active profile locally: python scripts/switch_env.py render

ENV_PROFILE=render
APP_ENV=production
AUTH_SECRET_KEY=generate-with-python-secrets-token-hex-32
AUTH_COOKIE_DAYS=7
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SAMESITE=lax
CORS_ORIGINS=https://forecast-pipeline-v2-frontend-nu.vercel.app,http://localhost:3000

DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require

# Render: single-line JSON only (paste full service account JSON)
GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}
GOOGLE_CREDENTIALS_PATH=/tmp/google-credentials.json

STORAGE_BACKEND=drive
PIPELINE_DRIVE_FOLDER_URL=https://drive.google.com/drive/folders/YOUR_SHARED_DRIVE_FOLDER_ID
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_STORAGE_BUCKET=input-output

# Do NOT set G:\ or /var/data paths — app uses backend/data/* on Render automatically

HUB_LEVEL_PLANNING_SHEET_URL=https://docs.google.com/spreadsheets/d/YOUR_SHEET_ID/edit
NEW_HUB_LAUNCH_SHEET_URL=https://docs.google.com/spreadsheets/d/YOUR_SHEET_ID/edit
DEMAND_PLANNING_MASTERS_SHEET_URL=https://docs.google.com/spreadsheets/d/YOUR_SHEET_ID/edit
CLUSTER_MASTER_SHEET_URL=https://docs.google.com/spreadsheets/d/YOUR_SHEET_ID/edit
AVAILABILITY_LOSS_SHEET_URL=https://docs.google.com/spreadsheets/d/YOUR_SHEET_ID/edit
DP_LOGICS_SHEET_URL=https://docs.google.com/spreadsheets/d/YOUR_SHEET_ID/edit
VALIDATION_SHEET_URL=https://docs.google.com/spreadsheets/d/YOUR_SHEET_ID/edit
EA_TRACKER_SHEET_URL=https://docs.google.com/spreadsheets/d/YOUR_SHEET_ID/edit
INVENTORY_BUFFER_SHEET_URL=https://docs.google.com/spreadsheets/d/YOUR_SHEET_ID/edit
PIPELINE_PARAMS_SHEET_URL=https://docs.google.com/spreadsheets/d/YOUR_SHEET_ID/edit

FROM_EMAIL=you@example.com
FROM_EMAIL_APP_PASSWORD=your-gmail-app-password

LOG_LEVEL=INFO
CACHE_WARMUP_DELAY_SECONDS=60
