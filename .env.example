# =============================================================================
# RENDER PRODUCTION ENV — copy/paste into Render → Environment → Import
# =============================================================================
#
# Render service settings:
#   Root directory : backend
#   Build command  : pip install -r requirements.txt
#   Start command  : uvicorn app.main:app --host 0.0.0.0 --port $PORT --workers 1
#   Health check   : /api/health/ready
#
# BEFORE importing: delete ALL existing env vars on Render (fresh import).
#
# DO NOT set any G:\ or /var/data paths — app uses backend/data/* automatically.
# Only set DATA_ROOT if you attached a Render persistent disk (see bottom).
#
# AFTER importing to Render, run ON YOUR LOCAL MACHINE:
#   cd backend
#   python scripts/push_pipeline_storage.py
# Then: Render → Manual Deploy
# 
# =============================================================================


# --- Core / auth ---
APP_ENV=xx
AUTH_SECRET_KEY=xx
AUTH_COOKIE_DAYS=xx
AUTH_COOKIE_SECURE=xx
AUTH_COOKIE_SAMESITE=xx
CORS_ORIGINS=xx


# --- Database (Supabase Postgres) ---
DATABASE_URL=xx


# --- Google service account (MUST be single line on Render) ---
GOOGLE_CREDENTIALS_JSON=xx
GOOGLE_CREDENTIALS_PATH=xx


# --- Shared Drive storage (source of truth for pipeline files) ---
STORAGE_BACKEND=xx
PIPELINE_DRIVE_FOLDER_URL=xx
SUPABASE_URL=xx
SUPABASE_SERVICE_ROLE_KEY=xx
SUPABASE_STORAGE_BUCKET=xx


# --- Google Sheets URLs ---
HUB_LEVEL_PLANNING_SHEET_URL=xx
NEW_HUB_LAUNCH_SHEET_URL=xx
DEMAND_PLANNING_MASTERS_SHEET_URL=xx
CLUSTER_MASTER_SHEET_URL=xx
AVAILABILITY_LOSS_SHEET_URL=xx
DP_LOGICS_SHEET_URL=xx
VALIDATION_SHEET_URL=xx
EA_TRACKER_SHEET_URL=xx
INVENTORY_BUFFER_SHEET_URL=xx
NEW_PRODUCT_LAUNCH_SHEET_URL=xx
PIPELINE_PARAMS_SHEET_URL=xx
NPL_SOURCE_SHEET_URL=xx
HUB_SKU_MASTER_SHEET_URL=xx
FF_AUTOMATION_SHEET_URL=xx


# --- Email (NPL notifications) ---
FROM_EMAIL=xx
FROM_EMAIL_APP_PASSWORD=xx


# --- Runtime tuning ---
LOG_LEVEL=INFO
CACHE_WARMUP_DELAY_SECONDS=xx
