# Planning Suite v2 — environment template (copy to backend/.env)
# See DEVELOPER_GUIDE.md for full descriptions.

APP_ENV=development
LOG_LEVEL=INFO

# Auth (required in production)
AUTH_SECRET_KEY=change-me-to-a-long-random-secret
AUTH_COOKIE_DAYS=7
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Database
DATABASE_URL=sqlite:///./planning_suite.db

# Pipeline file storage (optional — default local disk)
# STORAGE_BACKEND=local
# STORAGE_BACKEND=drive
# PIPELINE_DRIVE_FOLDER_URL=https://drive.google.com/drive/folders/YOUR_FOLDER_ID
# GOOGLE_DRIVE_IMPERSONATE_EMAIL=you@company.com   # only if folder is regular My Drive (Workspace delegation)
# STORAGE_BACKEND=supabase
# SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# SUPABASE_STORAGE_BUCKET=input-output
# Large files (≥6 MB) use TUS resumable uploads automatically.

# Frontend build (frontend/.env.local)
# NEXT_PUBLIC_API_URL=http://localhost:8000
# NEXT_PUBLIC_SENTRY_DSN=
# NEXT_PUBLIC_APP_ENV=development

# Error tracking (optional)
# SENTRY_DSN=
# SENTRY_TRACES_SAMPLE_RATE=0.1
