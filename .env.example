# Planning Suite v2 — environment template (copy to backend/.env)
# See DEVELOPER_GUIDE.md for full descriptions.

APP_ENV=development
LOG_LEVEL=INFO

# Auth (required in production)
AUTH_SECRET_KEY=change-me-to-a-long-random-secret
AUTH_COOKIE_DAYS=7
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Database
DATABASE_URL=sqlite:///./planning_suite.db

# Frontend build (frontend/.env.local)
# NEXT_PUBLIC_API_URL=http://localhost:8000
# NEXT_PUBLIC_SENTRY_DSN=
# NEXT_PUBLIC_APP_ENV=development

# Error tracking (optional)
# SENTRY_DSN=
# SENTRY_TRACES_SAMPLE_RATE=0.1
