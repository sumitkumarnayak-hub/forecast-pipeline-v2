{
    "services": {
        "frontend": {
            "root": "frontend",
            "framework": "nextjs",
            "env": {
                "BACKEND_URL": "https://forecast-pipeline-v2.onrender.com"
            }
        },
        "backend": {
            "root": "backend"
        }
    },
    "rewrites": [
        {
            "source": "/api/backend(/.*)?",
            "destination": {
                "type": "service",
                "service": "backend"
            }
        },
        {
            "source": "/(.*)",
            "destination": {
                "type": "service",
                "service": "frontend"
            }
        }
    ]
}
