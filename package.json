{
  "name": "forecast-pipeline-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "frontend"
  ],
  "scripts": {
    "setup": "npm install && npm run setup:backend",
    "setup:backend": "cd backend && python3 -m venv .venv && source .venv/bin/activate && pip install -r requirements.txt",
    "dev:frontend": "npm run dev --workspace=frontend",
    "dev:backend": "cd backend && source .venv/bin/activate && python run_backend.py",
    "dev": "concurrently --kill-others \"npm run dev:frontend\" \"npm run dev:backend\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
